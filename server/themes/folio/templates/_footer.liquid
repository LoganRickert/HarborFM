<footer class="folio-footer">
  <div class="folio-footer__inner">
    <div class="folio-footer__brand-block">
      <span class="folio-footer__brand">{{ podcast.title }}</span>
      {% if theme.homepage != "" %}
        <p class="folio-footer__theme">
          <a href="{{ theme.homepage | escape }}" rel="noopener noreferrer">{{ theme.name | escape }}</a>
          theme
        </p>
      {% else %}
        <p class="folio-footer__theme">{{ theme.name | escape }} theme</p>
      {% endif %}
    </div>
    <nav class="folio-footer__nav" aria-label="Footer">
      <a href="{{ urls.home }}">Home</a>
      <a href="{{ urls.pages.podcast }}">Episodes</a>
      <a href="{{ urls.pages.about }}">About</a>
      <a href="{{ urls.pages.crew }}">Crew</a>
      <a href="{{ urls.pages.support }}">Support</a>
      <a href="{{ urls.pages.connect }}">Connect</a>
    </nav>
  </div>
</footer>
