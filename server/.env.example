PORT=3001
DATA_DIR=./data
SECRETS_DIR=./secrets
JWT_SECRET=change-me-to-a-secure-secret-at-least-32-characters
# Optional:
# APP_NAME=HarborFM
# Dial-in IVR spoken brand ("Welcome to ...").
# DIAL_IN_IVR_NAME=
# Per-IP dial-in webhook rate limit (per minute). Default 30.
# DIAL_IN_WEBHOOK_RATE_LIMIT_MAX=30
# Telnyx TTS voice for dial-in prompts. Default female.
# DIAL_IN_TTS_VOICE=female
# Telnyx Call Control API base URL. Default https://api.telnyx.com/v2.
# TELNYX_API_BASE=https://api.telnyx.com/v2
# Dial-in abuse guards (per 10-minute window unless noted).
# DIAL_IN_MAX_PIN_FAILURES=10
# DIAL_IN_MAX_INBOUND_PER_CALLER=8
# DIAL_IN_MAX_CONCURRENT_LEGS_PER_CALLER=2
# DIAL_IN_MAX_CONCURRENT_LEGS_GLOBAL=20
# Scheduled group-call meeting windows and caps.
# MEETING_JOIN_OPENS_BEFORE_MS=3600000
# MEETING_JOIN_EXPIRES_AFTER_MS=14400000
# MAX_ACTIVE_MEETINGS_PER_USER=50
# MAX_SCHEDULE_AHEAD_MS=31536000000
# MEETING_INVITE_RATE_LIMIT_WINDOW_MS=300000
# MEETING_INVITE_RATE_LIMIT_MAX=5
# Theme catalog fetch limits.
# THEME_CATALOG_MAX_BYTES=1048576
# THEME_CATALOG_FETCH_TIMEOUT_MS=20000
# THEME_CATALOG_CACHE_TTL_MS=60000
# THEME_CATALOG_USER_AGENT=
# Theme rate limits (window 0 = no limit).
# THEME_IMPORT_RATE_LIMIT_WINDOW_MS=60000
# THEME_IMPORT_RATE_LIMIT_MAX=40
# THEME_UPDATE_RATE_LIMIT_WINDOW_MS=60000
# THEME_UPDATE_RATE_LIMIT_MAX=40
# THEME_DOWNLOAD_RATE_LIMIT_WINDOW_MS=60000
# THEME_DOWNLOAD_RATE_LIMIT_MAX=2
# THEME_CATALOG_RATE_LIMIT_WINDOW_MS=60000
# THEME_CATALOG_RATE_LIMIT_MAX=10
# FFPROBE_PATH=/usr/bin/ffprobe
# FFMPEG_PATH=/usr/bin/ffmpeg
# CREDENTIALS_ENCRYPTION_KEY=32-byte-hex-key
# PUBLIC_DIR=
# DATA_DIR=
# SECRETS_DIR=
# NODE_ENV=
# COOKIE_SECURE=
# HARBORFM_SECRETS_KEY=
