# Copy to aws/.env or vultr/.env and fill in your values:
#   cp .env.example aws/.env   # for AWS
#   cp .env.example vultr/.env # for Vultr

# Vultr (required when using vultr/)
# VULTR_API_KEY=your-vultr-api-key

# AWS (required when using aws/)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# Cloudflare (optional, for automatic DNS A records). run.sh maps this to TF_VAR_cloudflare_api_token.
# CLOUDFLARE_API_TOKEN=...
