{
  "name": "instance-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:frontend\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:frontend": "vite",
    "build": "vite build && tsc",
    "start": "node dist/index.js",
    "lint": "eslint src frontend/src"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^9.0.0",
    "dotenv": "^17.2.4",
    "execa": "^9.5.2",
    "fastify": "^5.7.4",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.1",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^6.0.3"
  }
