# Instance Manager server port (default 3999)
PORT=3999

# Monorepo root (default: two levels up from instance-manager). Set if you run from another cwd.
# INFRASTRUCTURE_ROOT=/path/to/harborfm

# Kubernetes: path to kubeconfig when managing Helm releases (optional)
# KUBECONFIG=~/.kube/config

# Default SSH public key (optional). Overrides config.json ssh_public_key when set. Used when deploy form leaves SSH key empty.
# DEFAULT_SSH_PUBLIC_KEY="ssh-rsa AAAAB3... you@host"

# Default admin API key (optional). Used when fetching system info for instances that do not have a per-instance key (e.g. Terraform/Helm). Can also be set in Settings (config.json).
# DEFAULT_ADMIN_API_KEY=your-harborfm-admin-api-key

# FlareVault (optional). When both set, Terraform deploys use FlareVault for admin credentials instead of inline user-data. Package is created before apply; redeem token is in user-data; after apply the package is PATCHed with server IP/32.
# FLAREVAULT_URL=https://flarevault.<sub>.workers.dev/my-prefix
# FLAREVAULT_ADMIN_TOKEN=your-flarevault-admin-bearer-token
