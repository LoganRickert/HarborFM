# Copy to .env and set your domain + email for Let's Encrypt.
# DOMAIN=yourdomain.com
# CERTBOT_EMAIL=you@yourdomain.com

DOMAIN=localhost
CERTBOT_EMAIL=

# Caddy only: required for on-demand TLS. Install/update scripts generate if missing.
# CADDY_TLS_CHECK_SECRET=your-secret-here

# Optional: timezone for fail2ban logs
# TZ=America/New_York
